# ---------- Candidate Portal's own Supabase project (bm-candidate-portal) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Shared bmave-core Supabase project (brands, candidates, portal_content, users) ----------
# Service role key is server-only. Never expose to the browser.
NEXT_PUBLIC_BMAVE_CORE_URL=
BMAVE_CORE_SERVICE_ROLE_KEY=

# ---------- Flightdeck Supabase project (candidate_applications + application-pdfs bucket) ----------
# Used by the application-submit flow to write the application
# mirror row and upload the generated PDF. Service role key is
# server-only — it can read/write any flightdeck table.
NEXT_PUBLIC_FLIGHTDECK_URL=
NEXT_PUBLIC_FLIGHTDECK_ANON_KEY=
FLIGHTDECK_SERVICE_ROLE_KEY=

# ---------- Zoho CRM (shared across Blue Maven projects) ----------
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# 32+ char random secret. Used by /api/webhooks/zoho-lead-created to
# HMAC-verify the X-Zoho-Webhook-Signature header. Generate fresh per
# environment; share with whoever configures the Zoho workflow.
ZOHO_WEBHOOK_SECRET=

# ---------- Email (Resend) ----------
RESEND_API_KEY=

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
