# Candidate Portal — required environment variables.
#
# Copy to .env.local for development. Vercel project settings hold the
# production values; keep secrets out of source control.

# ---------- Supabase: Candidate Portal's own project ----------
# Stores chapters_config / steps_config / candidates_in_portal /
# application_responses / bookings + the popup tables (chapter_videos,
# chapter_intro_popups, chapter_complete_popups, step_transition_popups).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Supabase: shared bmave-core project ----------
# Stores brands / candidates / portal_content / users / reps. Read by every
# Blue Maven app. The service role key is sensitive — server-side only.
NEXT_PUBLIC_BMAVE_CORE_URL=
BMAVE_CORE_SERVICE_ROLE_KEY=

# ---------- Google Calendar (service account) ----------
# Used by the schedule content type to read availability + book events.
# Private key must include literal \n line breaks; Vercel handles unescaping.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ---------- Google OAuth (admin sign-in) ----------
# Used by the @bmave.com sign-in flow at /admin/sign-in. Client must be
# configured with redirect URIs for every admin host (see DEPLOYMENT.md).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------- Site URL ----------
# Always the ADMIN domain. OAuth callback comes back here regardless of
# which subdomain the user is currently on (PR 46 — the brand portal
# subdomains don't accept admin sign-ins).
NEXT_PUBLIC_SITE_URL=https://flightdeck.bmave.com
